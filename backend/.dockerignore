# Exclude development artifacts and heavy local assets from Docker build context
__pycache__/
*.py[cod]
*.sqlite3
*.db
.env
.env.*
logs/
uploads/
train/
docs/
tests/

# Not needed to build/run backend service image, except chatbot corpus.
scripts/*
!scripts/corpus.json

# Keep only inference model artifacts required at runtime.
# Do not ignore the entire models/ directory because standalone docker run
# expects MODEL_PATH to be available inside the image.
models/*
!models/best_model_Hybrid_CNN_LSTM_Attention.h5
!models/best_model_CNN_Mejorada_Usuario.h5
