# Copia este archivo como .env y completa los valores antes de ejecutar docker-compose.
#   cp .env.example .env

# Clave secreta para JWT (genera una con: openssl rand -hex 32)
SECRET_KEY=cambia-esta-clave-secreta-en-produccion

# API Key de OpenAI para las explicaciones del clasificador y recomendaciones
# Si no se configura, el sistema usará textos de respaldo sin IA generativa
OPENAI_API_KEY=sk-pon-tu-api-key-aqui
OPENAI_MODEL=gpt-4o-mini

# URL del backend (usada por el frontend en tiempo de build)
# En producción, reemplaza con la IP o dominio del servidor
VITE_API_URL=http://localhost:8000
